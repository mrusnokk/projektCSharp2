<Window x:Class="Admin.BikeStatusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Změnit stav kola" Height="234" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock x:Name="CurrentStatusText" Margin="0,0,0,15"/>

        <TextBlock Text="Nový stav"/>
        <ComboBox x:Name="StatusCombo" Margin="0,0,0,10">
            <ComboBoxItem Content="available" Tag="available"/>
            <ComboBoxItem Content="maintenance" Tag="maintenance"/>
        </ComboBox>
        <TextBlock x:Name="StatusError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <TextBlock Text="Poznámka"/>
        <TextBox x:Name="NoteBox" Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Uložit" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Zrušit" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>