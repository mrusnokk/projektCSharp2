<Window x:Class="Admin.BikeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kolo" Height="280" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Kód kola"/>
        <TextBox x:Name="CodeBox" Margin="0,0,0,10"/>
        <TextBlock x:Name="CodeError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <TextBlock Text="Model"/>
        <TextBox x:Name="ModelBox" Margin="0,0,0,10"/>
        <TextBlock x:Name="ModelError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <TextBlock Text="ID stanoviště (prázdné = žádné)"/>
        <TextBox x:Name="StationBox" Margin="0,0,0,10"/>
        <TextBlock x:Name="StationError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Uložit" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Zrušit" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>