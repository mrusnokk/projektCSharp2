<Window x:Class="Admin.StationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stanoviště" Height="340" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Název"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,10"/>
        <TextBlock x:Name="NameError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <TextBlock Text="Adresa"/>
        <TextBox x:Name="AddressBox" Margin="0,0,0,10"/>

        <TextBlock Text="GPS Latitude"/>
        <TextBox x:Name="LatBox" Margin="0,0,0,10"/>
        <TextBlock x:Name="LatError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <TextBlock Text="GPS Longitude"/>
        <TextBox x:Name="LngBox" Margin="0,0,0,10"/>
        <TextBlock x:Name="LngError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <TextBlock Text="Kapacita"/>
        <TextBox x:Name="CapacityBox" Margin="0,0,0,15"/>
        <TextBlock x:Name="CapacityError" Foreground="Red" Visibility="Collapsed" Margin="0,-8,0,8"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Uložit" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Zrušit" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>