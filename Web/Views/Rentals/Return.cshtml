@using Web.ViewModels
@model ReturnViewModel
@{
	ViewData["Title"] = "Vrátit kolo";
}
<h2>Vrátit kolo</h2>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <h5 class="card-title">Vrácení kola #@Model.Rental.BikeId</h5>
        <p class="card-text">
            <strong>Půjčeno od:</strong> @Model.Rental.StartedAt.ToString("dd.MM.yyyy HH:mm")<br />
            <strong>Aktuální doba:</strong>
            @Math.Round((decimal)(DateTime.UtcNow - Model.Rental.StartedAt).TotalMinutes) minut
        </p>

        <form asp-action="Return" method="post">
            <input type="hidden" name="rentalId" value="@Model.Rental.Id" />

            <div class="mb-3">
                <label class="form-label">Vyberte stanoviště pro vrácení</label>
                <select name="endStationId" class="form-select">
                    @foreach (var station in Model.Stations)
                    {
                        <option value="@station.Id">@station.Name</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-danger">Potvrdit vrácení</button>
            <a asp-controller="Rentals" asp-action="Index" class="btn btn-secondary">Zrušit</a>
        </form>
    </div>
</div>